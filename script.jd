const infoModal = document.getElementById('infoModal');
const modalTitle = document.getElementById('modalTitle');
const modalDetails = document.getElementById('modalDetails');

// Duomenų bazė šablonams
const templateData = {
    "AutoPro": {
        specs: ["Registracijos forma", "Kainoraštis", "Meistrų skiltis", "Google Maps"],
        demoUrl: "https://webstore.lt",
        delivery: "24 val."
    },
    "ArtisanGo": {
        specs: ["Portfolio galerija", "Instagram integracija", "Atsiliepimai", "Kontaktų forma"],
        demoUrl: "https://webstore.lt",
        delivery: "24 val."
    },
    "BuildMaster": {
        specs: ["Prieš/Po slankiklis", "Kainos skaičiuoklė", "Objektų žemėlapis", "Sertifikatai"],
        demoUrl: "https://webstore.lt",
        delivery: "48 val."
    }
    // Pridėkite kitus šablonus pagal pavadinimą (ID)
};

document.querySelectorAll('.view-demo').forEach(link => {
    link.addEventListener('click', (e) => {
        e.preventDefault();
        
        // Paimame pavadinimą iš kortelės (pvz. "AutoPro")
        const cardTitle = link.closest('.card').querySelector('.card-img').innerText;
        const data = templateData[cardTitle] || { specs: ["Standartinės funkcijos"], demoUrl: "#", delivery: "24 val." };

        modalTitle.innerText = cardTitle + " – Išsami informacija";
        
        modalDetails.innerHTML = `
            <div style="background: #f8fafc; padding: 15px; border-radius: 10px; margin-bottom: 20px;">
                <p><strong>Pristatymas:</strong> paruošime per ${data.delivery}</p>
                <p><strong>Kas įeina į paketą:</strong></p>
                <ul style="padding-left: 20px;">
                    ${data.specs.map(s => `<li>✅ ${s}</li>`).join('')}
                    <li>✅ Hostingas + SSL (1 metai)</li>
                </ul>
            </div>
            <div style="display: flex; gap: 10px;">
                <a href="${data.demoUrl}" target="_blank" class="btn secondary" style="flex: 1; text-align: center;">Žiūrėti tikrą demo ↗</a>
            </div>
        `;
        
        infoModal.style.display = 'flex';
    });
});


