const contactForm = document.querySelector('.contact-form');

if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // 1. Tikriname Honeypot lauką
        const botTrap = document.getElementById('b_field').value;
        if (botTrap !== "") {
            console.warn("Spam detected and blocked.");
            return; // Sustabdome siuntimą, jei laukas užpildytas
        }

        // 2. Vizualinis grįžtamasis ryšys (Sales Assistant mode)
        const btn = contactForm.querySelector('button');
        const originalText = btn.innerText;
        
        btn.innerText = "Siunčiama...";
        btn.disabled = true;

        // Imituojame siuntimą (arba čia jungiame Netlify/kitą servisą)
        setTimeout(() => {
            // Sukuriame gražų pranešimą vietoje paprasto alert
            btn.style.background = "#00ff88";
            btn.innerText = "Žinutė išsiųsta! ✓";
            
            setTimeout(() => {
                btn.innerText = originalText;
                btn.style.background = "";
                btn.disabled = false;
                contactForm.reset();
            }, 3000);
        }, 1500);
    });
}


// SLAPUKŲ LOGIKA
const cookieBanner = document.getElementById('cookie-banner');
const acceptBtn = document.getElementById('accept-cookies');

// Patikriname, ar vartotojas jau buvo sutikęs anksčiau
if (!localStorage.getItem('cookiesAccepted')) {
    setTimeout(() => {
        cookieBanner.classList.add('show');
    }, 2000); // Atsiranda po 2 sekundžių
}

acceptBtn.addEventListener('click', () => {
    localStorage.setItem('cookiesAccepted', 'true');
    cookieBanner.classList.remove('show');
});
